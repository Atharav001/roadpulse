# Leave empty in local dev — Vite proxies /api → http://localhost:5001
# On Vercel, set this to your public backend URL (no trailing slash)
VITE_API_URL=

# Google Identity Services (OAuth Web Client ID)
# Create at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:3000 and your Vercel URL
VITE_GOOGLE_CLIENT_ID=
