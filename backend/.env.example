# RoadPulse Complete Environment Configuration
# Copy this to backend/.env and fill in your actual values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection string
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# For local development: postgresql://postgres:postgres@localhost:5432/roadpulse
# For production: Use environment variable from hosting provider (e.g., Heroku, AWS RDS)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/roadpulse

# ============================================================================
# EXTERNAL API KEYS & CONFIGURATION
# ============================================================================

# Google Places API Key
# Used by: Landmark Agent (src/agents/landmark.js)
# Get from: https://console.cloud.google.com/
# Steps: Enable Places API → Create API key → Restrict to Places API
# For DEMO/TESTING: Use any non-empty string (system has graceful fallback)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Google Geocoding API Key
# Used by: Landmark Agent for reverse geocoding (lat/lon → address)
# Get from: https://console.cloud.google.com/
# Steps: Enable Geocoding API → Create API key
# For DEMO/TESTING: Use any non-empty string
GOOGLE_GEOCODING_API_KEY=your_google_geocoding_api_key_here

# Vision/Classification Model Configuration
# Used by: Classification Agent (src/agents/classification.js)
# Options: "gemini-2.5-flash" (default) or "gpt-4-mini"
# Get API key from:
#   - For Gemini: https://ai.google.dev/ → Get API Key
#   - For GPT-4: https://platform.openai.com/account/api-keys
# For DEMO/TESTING: Use any non-empty string (fallback: "unclassified")
VISION_MODEL_API_KEY=your_vision_model_api_key_here
VISION_MODEL_PROVIDER=gemini  # Options: "gemini" or "openai"

# ============================================================================
# SERVER & ENVIRONMENT CONFIGURATION
# ============================================================================

# Node.js Environment
# Values: "development", "production", "test"
# development: Verbose logging, nodemon auto-restart
# production: Minimal logging, optimized performance
NODE_ENV=development

# Backend Server Port
# Local default for this project: 5001 (frontend Vite proxies /api → 5001)
PORT=5001

# Google OAuth Web Client ID (must match frontend VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# Comma-separated frontend origins for CORS (Vercel URL in production)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_VERCEL=true

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT Secret for Token Generation
# Used by: Auth routes (src/routes/auth.js)
# IMPORTANT: Use a strong, random string in production
# Generate: `openssl rand -base64 32`
# For DEMO: Can use simple string
JWT_SECRET=roadpulse-hackathon-secret-key-do-not-use-in-production

# Token Expiration Time
# Format: As accepted by `ms` package (e.g., "7d", "24h", "1w")
# Default: "7d" (7 days)
JWT_EXPIRATION=7d

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# Frontend Server Port (used by Vite)
# Default: 5173
# Change if port already in use
VITE_PORT=5173

# API Base URL (used by frontend)
# Development: http://localhost:5000
# Production: https://api.roadpulse.com
REACT_APP_API_URL=http://localhost:5000

# ============================================================================
# LOGGING & DEBUG
# ============================================================================

# Debug Mode
# Options: "true" or "false"
# When true: Verbose logs from agents, API routes, database queries
DEBUG=true

# Log Level
# Options: "error", "warn", "info", "debug", "trace"
# Default: "info"
LOG_LEVEL=info

# ============================================================================
# CLUSTERING & DISTANCE MATCHING
# ============================================================================

# Haversine Distance Threshold (in meters)
# Used by: Clustering Agent (src/agents/clustering.js)
# Default: 30 (reports within 30m are considered duplicates)
# Adjust for your city/region:
#   - Urban (dense): 20-30m
#   - Suburban: 50-100m
#   - Rural: 200-500m
CLUSTERING_DISTANCE_THRESHOLD=15

# ============================================================================
# EMAIL AGENT CONFIGURATION
# ============================================================================

# Email Model Provider
# Used by: Email Draft Agent (src/agents/emailDraft.js)
# Options: "openai", "anthropic"
# Default: "openai"
EMAIL_MODEL_PROVIDER=openai

# Default Sender Email
# Used in draft emails
DEFAULT_SENDER_EMAIL=noreply@roadpulse.local

# ============================================================================
# DEMO / TEST MODE
# ============================================================================

# Enable Demo/Fallback Mode
# When true: Agents use graceful fallbacks instead of failing
# Set to false in production to see actual API errors
DEMO_MODE=true

# Use Mock Data for Testing
# When true: Seed database with sample incidents/users for demo
USE_MOCK_DATA=true

# ============================================================================
# OPTIONAL: ADVANCED CONFIGURATION
# ============================================================================

# CORS (Cross-Origin Resource Sharing) Origins
# Comma-separated list of allowed frontend URLs
# Development: http://localhost:5173,http://localhost:3000
# Production: https://app.roadpulse.com,https://www.roadpulse.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database Connection Pool Size
# Default: 20
# Adjust based on expected concurrent connections
DB_POOL_SIZE=20

# Request Size Limit (for file uploads)
# Default: 10mb
REQUEST_SIZE_LIMIT=10mb

# Photo Upload Temporary Directory
# Default: ./tmp
UPLOAD_TEMP_DIR=./tmp

# ============================================================================
# QUICKSTART FOR JUDGES
# ============================================================================
#
# For a QUICK DEMO (< 5 minutes), use these defaults:
#
# 1. Copy this file: cp .env.example.complete backend/.env
# 2. Leave all API keys as placeholders (demo mode enabled)
# 3. Ensure PostgreSQL is running (or update DATABASE_URL)
# 4. Run: npm run migrate && npm run seed
# 5. Run: npm run dev
#
# All 10 features work with graceful fallbacks!
#
# For real API integration:
# 1. Get API keys from Google Cloud & OpenAI/Anthropic
# 2. Set DEMO_MODE=false
# 3. Update VISION_MODEL_API_KEY, GOOGLE_PLACES_API_KEY, etc.
#
# ============================================================================
